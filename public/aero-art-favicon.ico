<svg width="64" height="64" viewBox="0 0 64 64" role="img" xmlns="http://www.w3.org/2000/svg">
  <title>Aero Art Favicon</title>
  <desc>Favicon für das Bläserquintett Aero Art</desc>

  <rect width="64" height="64" fill="#080810" rx="8"/>
  <circle cx="32" cy="32" r="28" fill="none" stroke="#c8963e" stroke-width="1" opacity="0.3"/>
  <circle cx="32" cy="32" r="22" fill="#0f0f1a" stroke="#c8963e" stroke-width="1.5"/>

  <!-- AA Ligatur -->
  <g transform="translate(32,32)">
    <line x1="-10" y1="9" x2="-1" y2="-9" stroke="#c8963e" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="10" y1="9" x2="1" y2="-9" stroke="#c8963e" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="-10" y1="9" x2="-15" y2="9" stroke="#c8963e" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="10" y1="9" x2="15" y2="9" stroke="#c8963e" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="-1" y1="-9" x2="0" y2="9" stroke="#c8963e" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="-11" y1="2" x2="-1" y2="2" stroke="#c8963e" stroke-width="1.4" stroke-linecap="round"/>
    <line x1="1" y1="2" x2="11" y2="2" stroke="#c8963e" stroke-width="1.4" stroke-linecap="round"/>
  </g>
</svg>
